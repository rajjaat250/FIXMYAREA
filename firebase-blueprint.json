{
  "features": {
    "firestore": true,
    "authentication": true
  },
  "collections": [
    {
      "name": "reports",
      "rules": [
        {
          "allow": "read",
          "condition": "true"
        },
        {
          "allow": "create",
          "condition": "request.auth != null"
        },
        {
          "allow": "update, delete",
          "condition": "request.auth != null && request.auth.token.email == 'dhariwalraj37@gmail.com'"
        }
      ]
    }
  ]
}
